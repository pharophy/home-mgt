<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <httpErrors errorMode="Detailed" existingResponse="PassThrough" />
    <rewrite>
      <rules>
        <rule name="StarstepReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action
            type="Rewrite"
            url="http://127.0.0.1:3001/{R:1}"
            logRewrittenUrl="true"
          />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
