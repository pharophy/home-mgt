{
  "name": "home-mgt",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "start": "npm run start --workspace server",
    "start:prod": "node scripts/prod.mjs",
    "prod": "node scripts/prod.mjs",
    "prod:startup:install": "node scripts/windows-prod-startup.mjs install",
    "prod:startup:uninstall": "node scripts/windows-prod-startup.mjs uninstall",
    "test:prod": "node scripts/prod-launcher.test.mjs",
    "test:startup": "node scripts/windows-prod-startup.test.mjs",
    "smoke:starstep": "node scripts/smoke-check-starstep.mjs",
    "test": "npm run test --workspace server",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2"
  }
}
